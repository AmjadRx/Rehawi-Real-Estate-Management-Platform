{
  "mcpServers": {
    "motion": {
      "command": "npx",
      "args": [
        "-y",
        "https://api.motion.dev/registry.tgz?package=motion-studio-mcp&version=6.1.0"
      ],
      "env": {
        "TOKEN": "${MOTION_TOKEN}"
      }
    },
    "css-studio": {
      "command": "npx",
      "args": [
        "-y",
        "cssstudio"
      ]
    }
  }
}