# Copy to .env.local for local development. NEVER commit .env.local.
# All values are set in Vercel → Settings → Environment Variables for production.

# Neon Postgres (from Vercel Marketplace integration).
# Leave unset in local dev to use the embedded PGlite database (.data/pg).
DATABASE_URL=

# Vercel Blob (auto-added by the integration). Unset locally → files stored in .data/uploads.
BLOB_READ_WRITE_TOKEN=

# Sessions & OTP secrets — 32+ random bytes each (e.g. `openssl rand -hex 32`)
SESSION_SECRET=dev-only-secret-change-me-0000000000000000
OTP_PEPPER=dev-only-pepper-change-me-0000000000000000

# Allowlist (§3.1) — comma-separated; phones in E.164
ALLOWED_EMAILS=dev@example.com
ALLOWED_PHONES=
ADMIN_EMAILS=dev@example.com
ADMIN_PHONES=

# Auth mode (§3.2 v4). "db_password" (default): allowlisted users create
# their own password once with SETUP_CODE; the argon2id hash lives in the
# database so the same credentials work on the site and the app. Switch to
# "otp" once Resend/Twilio keys exist. (The old AUTH_USERS variable is
# deprecated: remove it.)
AUTH_MODE=db_password
# One-time family setup code, shared privately with family members.
SETUP_CODE=family-setup-code-change-me

# CORS (§7 v4): comma-separated web origins allowed to call the API
# (Replit preview, Expo web). Native app requests need no entry here.
CORS_ORIGINS=

# Address search (/api/v1/geo). Leave unset to use Nominatim (OpenStreetMap,
# free, zero signup, rate-limited). Set a Geoapify key (free tier ~3k/day,
# simple email signup) for the higher-volume upstream. Never shipped to clients.
GEOCODER_API_KEY=

# OTP delivery (AUTH_MODE=otp). Unset locally → codes are printed to the server console (dev only).
RESEND_API_KEY=
OTP_FROM_EMAIL="Rehawi Estates <code@example.com>"
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Maps: site maps use MapLibre + OpenStreetMap tiles (free, no key needed).

BASE_CURRENCY=EUR
CRON_SECRET=dev-cron-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000
